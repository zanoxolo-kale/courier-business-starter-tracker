generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformName {
  ALL
  MR_D
  BOLT
  UBER_EATS
  UBER_PASSENGERS
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum DocumentStatus {
  MISSING
  IN_PROGRESS
  READY
  UPLOADED
  REJECTED
  EXPIRED
